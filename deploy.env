# ── RustDesk Custom Server Configuration ──────────────────────────────────────
# Edit this file before building. All values get baked into the app.

# Rendezvous server (hbbs) - IP or domain
RENDEZVOUS_SERVER=192.168.50.28

# Relay server (hbbr) - usually same as rendezvous
RELAY_SERVER=192.168.50.28

# Public key from hbbs (cat /path/to/data/id_ed25519.pub)
SERVER_KEY=Jf5elrunPtjOAXfEVt5hsx6kTTjlrwGjQEMiJ1qJHuQ=

# Support server URL (where the "Request Support" button posts to)
SUPPORT_SERVER_URL=http://192.168.50.28:3030

