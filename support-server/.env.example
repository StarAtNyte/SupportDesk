# ── SupportDesk Server Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Used by: docker-compose.yml (support-server)

# ── RustDesk Server ───────────────────────────────────────────────────────────
# IP or domain of your hbbs/hbbr server
SERVER_HOST=192.168.50.28

# Public key from hbbs (cat ~/rustdesk-server/data/id_ed25519.pub)
SERVER_KEY=Jf5elrunPtjOAXfEVt5hsx6kTTjlrwGjQEMiJ1qJHuQ=

# Full URL to this support server (used by email notifications)
SERVER_URL=http://192.168.50.28:3030

# ── Gmail Notifications ────────────────────────────────────────────────────────
# Sending Gmail account + App Password (myaccount.google.com/apppasswords)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Where to deliver the notification
NOTIFY_EMAIL=admin@yourcompany.com
